{
  "name": "mindpro-ipms-front",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:common": "turbo run build --filter=common",
    "build:business": "turbo run build --filter=business",
    "build:partner": "turbo run build --filter=partner",
    "build:personal": "turbo run build --filter=personal",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "preinstall": "node scripts/ensure-root-install.cjs"
  },
  "pnpm": {
    "overrides": {
      "react-is": "^19.2.3",
      "@types/react": "19.2.3",
      "@types/react-dom": "19.2.3"
    }
  },
  "devDependencies": {
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@types/react-signature-canvas": "^1.0.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.2",
    "turbo": "^2.6.3",
    "typescript": "5.9.2",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.0.1"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@repo/assets": "workspace:^",
    "@tanstack/react-query": "^5.90.12",
    "i18next": "^23.0.0",
    "pg": "^8.20.0",
    "react-hook-form": "^7.68.0",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^7.10.1",
    "react-signature-canvas": "1.1.0-alpha.2",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  }
}
